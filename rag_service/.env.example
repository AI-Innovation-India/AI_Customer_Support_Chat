# ═══════════════════════════════════════════════════════════════════
# RAG Knowledge Base Service — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════════

# ── EMBEDDING BACKEND ────────────────────────────────────────────
# For production: use Azure OpenAI (same account as your chat backend)
# For testing:    use plain OpenAI API key

# Set to "true" to use Azure OpenAI for embeddings (recommended for production)
USE_AZURE_EMBEDDINGS=false

# --- Azure OpenAI (production) ---
# Same endpoint and key as your Node.js AZURE_ENDPOINT / AZURE_KEY
AZURE_ENDPOINT=https://your-resource.openai.azure.com
AZURE_KEY=your_azure_openai_key_here
AZURE_API_VERSION=2024-02-01
# The name of your Azure embedding deployment (create in Azure AI Studio)
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small

# --- Plain OpenAI (testing / no Azure) ---
# Used when USE_AZURE_EMBEDDINGS=false
OPENAI_API_KEY=your_openai_api_key_here

# ── WEB SEARCH FALLBACK (optional but recommended) ───────────────
# When the knowledge base has no answer, Yazhni searches trane.com
# and thermoking.com instead of guessing.
# Get a free Tavily key at: https://app.tavily.com (1000 searches/month free)
# Leave blank to disable — AI will say "I don't have that info" instead.
TAVILY_API_KEY=

# ── KNOWLEDGE BASE STORAGE ───────────────────────────────────────
# Where FAISS index and document metadata are stored on disk
KB_STORAGE_PATH=./knowledge_base

# ── RETRIEVAL SETTINGS ───────────────────────────────────────────
# Maximum chunks returned per query
TOP_K_RESULTS=5
# Minimum similarity score (0-1) to include a chunk — below this = not relevant
# 0.25 is a good starting point; raise to 0.35 to be stricter
MIN_RELEVANCE_SCORE=0.25

# ── CHUNKING SETTINGS ────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
