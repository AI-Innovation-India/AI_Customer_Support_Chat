# ═══════════════════════════════════════════════════════════════════
# RAG Knowledge Base Service — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
#
# NO OpenAI / Azure embedding key needed — Pinecone embeds for you.
# ═══════════════════════════════════════════════════════════════════

# ── PINECONE (required) ──────────────────────────────────────────
# Get free key: https://app.pinecone.io → API Keys (no credit card)
# Free tier: 1 index, built-in multilingual embeddings included
PINECONE_API_KEY=your_pinecone_api_key_here

# Index name — will be created automatically on first run
PINECONE_INDEX_NAME=trane-thermoking-kb

# Cloud + region for the serverless index (free tier = aws us-east-1)
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── WEB SEARCH FALLBACK (optional) ──────────────────────────────
# When KB has no answer, searches trane.com + thermoking.com only.
# Free key: https://app.tavily.com (1000 searches/month free)
# Leave blank to disable — AI will say "I don't have that info"
TAVILY_API_KEY=

# ── RETRIEVAL SETTINGS ───────────────────────────────────────────
KB_STORAGE_PATH=./knowledge_base
TOP_K_RESULTS=5
# Chunks scoring below this are dropped (0=accept all, 0.5=strict)
MIN_RELEVANCE_SCORE=0.25

# ── CHUNKING SETTINGS ────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
