# OpenAI — used for embeddings (text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# Where FAISS index + doc metadata are persisted on disk
KB_STORAGE_PATH=./knowledge_base

# Chunk settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RESULTS=5

# Optional: Neo4j for Knowledge Graph RAG (leave blank to use FAISS only)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
