# ═══════════════════════════════════════════════════════════════════
# RAG Knowledge Base Service — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════════════

# ── AZURE OPENAI — for embeddings (text-embedding-3-small) ───────
# Same endpoint + key as your main .env (Node.js backend)
AZURE_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_KEY=your_azure_key_here
AZURE_API_VERSION=2024-02-01
# Name of your embedding deployment in Azure AI Studio
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small

# ── PINECONE — vector store ───────────────────────────────────────
# Free key: https://app.pinecone.io (no credit card)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=trane-thermoking-kb
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── NEO4J AURADB — Knowledge Graph (optional but recommended) ────
# Sign up free at: https://neo4j.com/cloud/aura
# Click "Create Free Instance" → copy Connection URI, Username, Password
# URI format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_auradb_password_here

# ── WEB SEARCH FALLBACK (optional) ──────────────────────────────
# Searches trane.com + thermoking.com when KB has no answer
# Free key: https://app.tavily.com (1000 searches/month)
TAVILY_API_KEY=

# ── SETTINGS ─────────────────────────────────────────────────────
KB_STORAGE_PATH=./knowledge_base
TOP_K_RESULTS=5
MIN_RELEVANCE_SCORE=0.25
CHUNK_SIZE=800
CHUNK_OVERLAP=150
