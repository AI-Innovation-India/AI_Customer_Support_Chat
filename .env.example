# ═══════════════════════════════════════════════════════════════
# Trane & ThermoKing Support Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Restrict which origins can call the API (your app's domain)
# Use * only for local dev — always set a real origin in production
ALLOWED_ORIGIN=http://localhost:3001

# ── AGENT AUTH ───────────────────────────────────────────────
# Support staff login credentials
# For multiple agents, use a JSON array:  [{"user":"agent1","pass":"secret1"},{"user":"agent2","pass":"secret2"}]
AGENT_USERS=[{"user":"admin","pass":"changeme123"}]

# Secret used to sign JWT tokens — use a long random string
JWT_SECRET=replace_this_with_a_long_random_secret_string_at_least_64_chars

# Token expiry (8h = one work shift)
JWT_EXPIRY=8h

# ── SARVAM AI (Speech-to-Text + Text-to-Speech) ──────────────
# Get your key at: https://api.sarvam.ai
SARVAM_KEY=your_sarvam_api_key_here

# ── AI CHAT BACKEND (choose one or both) ─────────────────────

# Option A: Groq (recommended — truly free, no billing)
# Get free key at: https://console.groq.com → API Keys
GROQ_KEY=your_groq_api_key_here

# Option B: Azure OpenAI (office/enterprise)
AZURE_ENDPOINT=https://your-resource.openai.azure.com
AZURE_DEPLOYMENT=gpt-35-turbo
AZURE_KEY=your_azure_openai_key_here

# Set to "true" to use Azure instead of Groq
USE_AZURE=false

# ── RAG KNOWLEDGE BASE SERVICE ───────────────────────────────
# URL of the Python FastAPI RAG microservice (rag_service/main.py)
# Leave as default if running on the same machine
RAG_SERVICE_URL=http://localhost:8000

# ── CRM / TICKETING INTEGRATION (optional) ───────────────────
# POST session JSON to this URL when a session ends
# Leave blank to disable
CRM_WEBHOOK_URL=

# Optional: shared secret header for your CRM webhook
CRM_WEBHOOK_SECRET=

# ── SESSION EXPORTS ───────────────────────────────────────────
# Directory where session JSON files are saved (relative to project root)
EXPORTS_DIR=./exports

# ── EMAIL / TICKET SYSTEM ────────────────────────────────────────
# Microsoft 365 / Outlook (recommended for office use):
EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_USER=support@yourcompany.com
EMAIL_PASSWORD=your_outlook_password_here
# NOTE: If MFA is ON — go to Microsoft 365 Admin → Users → your account
#       → Mail → Manage email apps → enable "Authenticated SMTP"

# Gmail (personal/dev use — create App Password at myaccount.google.com/apppasswords):
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_16char_app_password

# CS team inbox — all tickets are sent HERE
CS_EMAIL=cs-team@yourcompany.com

# Customer is auto CC'd if they gave their email in the intake form
